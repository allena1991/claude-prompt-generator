# AWS Configuration for Bedrock
REGION_NAME=us-east-1

# Optional: OpenAI API for evaluation (if using the evaluation features)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=

# Note: You must also configure AWS credentials using one of:
# 1. AWS CLI: aws configure
# 2. Environment variables: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY
# 3. IAM roles (if running on EC2)
# 4. AWS credentials file (~/.aws/credentials)

# Required AWS Bedrock Models:
# - anthropic.claude-3-haiku-20240307-v1:0 (for metaprompt generation)
# - anthropic.claude-3-sonnet-20240229-v1:0 (for clinical guidelines)